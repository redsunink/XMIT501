<Project Sdk="Microsoft.NET.Sdk.WindowsDesktop">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <UseWPF>true</UseWPF>
    <Nullable>enable</Nullable>
    <SelfContained>false</SelfContained> 
    <ApplicationIcon>..\assets\icon.ico</ApplicationIcon>

    <GenerateAssemblyInfo>true</GenerateAssemblyInfo>
    <AssemblyName>XMIT501</AssemblyName>
    <Version>1.0.0.0</Version>
    <Authors>Red Sun</Authors>
    <Company>RedTec</Company>
    <Product>XMIT501 Tactical Radio</Product>
    <Description>Lightweight VoIP Radio for gaming. Written with AI.</Description>
    <Copyright>CC0</Copyright>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="NAudio" Version="2.2.1" />
    <PackageReference Include="Concentus" Version="2.0.1" />
    <PackageReference Include="Open.NAT" Version="2.1.0" />
    <PackageReference Include="SharpDX.DirectInput" Version="4.2.0" />
  </ItemGroup>

  <ItemGroup>
    <Resource Include="..\assets\**\*.*" Link="assets\%(RecursiveDir)%(Filename)%(Extension)" />
    <Resource Include="..\fonts\**\*.*" Link="fonts\%(RecursiveDir)%(Filename)%(Extension)" />
  </ItemGroup>

</Project>